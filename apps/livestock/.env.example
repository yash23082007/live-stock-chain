# App
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-secret-key-here
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Database (Supabase PostgreSQL)
DATABASE_URL=postgresql://postgres:password@localhost:5432/livestockchain

# NextAuth
NEXT_PUBLIC_AUTH_PROVIDERS=github,google

# Blockchain (Polygon Amoy Testnet)
NEXT_PUBLIC_ALCHEMY_URL=https://polygon-amoy.g.alchemy.com/v2/your-key
BLOCKCHAIN_PRIVATE_KEY=your-server-wallet-private-key
NEXT_PUBLIC_LIVESTOCK_REGISTRY_ADDRESS=0x...
NEXT_PUBLIC_HEALTH_ANCHOR_ADDRESS=0x...
NEXT_PUBLIC_FARM_REGISTRY_ADDRESS=0x...
NEXT_PUBLIC_CHAIN_ID=80002

# IPFS (Web3.Storage)
WEB3_STORAGE_TOKEN=your-token

# Email (Resend)
RESEND_API_KEY=your-key
RESEND_FROM_EMAIL=alerts@livestockchain.app

# Error Monitoring (Sentry)
NEXT_PUBLIC_SENTRY_DSN=https://xxx@sentry.io/xxx
