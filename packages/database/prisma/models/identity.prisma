enum UserRole {
  FARMER
  AGENT
  SUPPLIER
  VETERINARIAN
  BUYER
  ADMIN
  SUPER_ADMIN
}

enum KYCStatus {
  PENDING
  SUBMITTED
  VERIFIED
  REJECTED
}

model User {
  id           String   @id @default(cuid())
  fullName     String?
  phone        String   @unique
  email        String?  @unique
  passwordHash String
  walletAddress String? @unique
  role         UserRole @default(FARMER)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  farmer    Farmer?
  agent     Agent?
  supplier  Supplier?
  sessions  Session[]
  auditLogs AuditLog[]

  @@index([phone])
  @@index([walletAddress])
  @@map("users")
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  refreshToken String   @unique
  deviceInfo   Json?
  ipAddress    String?
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model AuditLog {
  id         String   @id @default(cuid())
  userId      String?
  action      String
  resource    String
  resourceId  String?
  oldValue    Json?
  newValue    Json?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([resource, resourceId])
  @@index([createdAt])
  @@map("audit_logs")
}
