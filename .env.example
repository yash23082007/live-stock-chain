# App
NODE_ENV=production
PORT=3001
ALLOWED_ORIGINS=https://app.farmfinance.co,https://admin.farmfinance.co

# Database
DATABASE_URL=postgresql://user:pass@db.internal:5432/farmfinance?ssl=true

# Redis
REDIS_URL=redis://:password@redis.internal:6379

# Auth
JWT_SECRET=<min-32-char-random-string>
JWT_REFRESH_EXPIRY=30d

# AWS
AWS_REGION=af-south-1
AWS_ACCESS_KEY_ID=...
AWS_SECRET_ACCESS_KEY=...
S3_BUCKET=farmfinance-documents-prod

# SMS (Africa's Talking)
AT_API_KEY=...
AT_USERNAME=farmfinance

# Blockchain (Optional)
RPC_URL=https://polygon-rpc.com
PRIVATE_KEY=...
CONTRACT_ADDRESS=0x...

# Monitoring
SENTRY_DSN=https://...@sentry.io/...

